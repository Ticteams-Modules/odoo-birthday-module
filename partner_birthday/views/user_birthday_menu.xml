<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top-level application menu -->
    <menuitem id="menu_partner_birthday_root"
              name="Birthdays"
              web_icon="partner_birthday,static/description/icon.png"
              sequence="100"/>

    <!-- Birthday list menu -->
    <menuitem id="menu_partner_birthday_list"
              name="Upcoming Birthdays"
              parent="menu_partner_birthday_root"
              action="action_partner_birthday"
              sequence="10"/>

    <!-- Configuration submenu (link to standard contacts) -->
    <menuitem id="menu_partner_birthday_configuration"
              name="Configuration"
              parent="menu_partner_birthday_root"
              sequence="90"/>

    <menuitem id="menu_partner_birthday_contacts"
              name="Contacts"
              parent="menu_partner_birthday_configuration"
              action="base.action_res_partner"
              sequence="10"/>

</odoo>
