<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top-level application menu -->
    <menuitem id="menu_user_birthday_root"
              name="Birthdays"
              web_icon="user_birthday,static/description/icon.png"
              sequence="100"/>

    <!-- Birthday list menu -->
    <menuitem id="menu_user_birthday_list"
              name="Upcoming Birthdays"
              parent="menu_user_birthday_root"
              action="action_users_birthday"
              sequence="10"/>

    <!-- Configuration submenu (link to standard users) -->
    <menuitem id="menu_user_birthday_configuration"
              name="Configuration"
              parent="menu_user_birthday_root"
              sequence="90"/>

    <menuitem id="menu_user_birthday_users"
              name="Users"
              parent="menu_user_birthday_configuration"
              action="base.action_res_users"
              sequence="10"/>

</odoo>
