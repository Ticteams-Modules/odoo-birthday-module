<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Daily scheduled action: send birthday popup notifications -->
        <record id="ir_cron_user_birthday_notification" model="ir.cron">
            <field name="name">User Birthday: Daily Notification</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_birthday_notifications()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="priority">5</field>
        </record>

    </data>
</odoo>
