<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <data>
        <record id="view_payment_wizard_form" model="ir.ui.view">
            <field name="name">payment.wizard.form</field>
            <field name="model">payment.wizard</field>
            <field name="arch" type="xml">
                <form string="Métodos de Pago">
                    <group>
                        <field name="payment_line_ids">
                            <list editable="bottom">
                                <field name="amount"/>
                                <field name="date"/>
                                <field name="pa_payment_method"/>
                            </list>
                        </field>
                    </group>
                    <footer>
                        <button string="Confirmar" type="object" name="action_confirm" class="oe_highlight" data-hotkey="r"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>