<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<template id="report_invoice_document" inherit_id="account.report_invoice_document">
		<xpath expr="//div[@class='clearfix invoice_main']" position="replace">
			<h2>
				<t t-if="o.move_type == 'out_invoice' and o.pa_doc_name">
					<span t-field="o.pa_doc_name" />: </t>
				<span
					t-if="o.move_type == 'out_invoice' and (o.state == 'open' or o.state == 'paid') and not o.pa_doc_name">
					Invoice</span>
				<span t-if="o.move_type == 'out_invoice' and o.state == 'proforma2'">PRO-FORMA</span>
				<t t-if="o.move_type == 'out_invoice' and o.state == 'draft' and o.pa_doc_name">
					Draft <span t-field="o.pa_doc_name" />
				</t>
				<span
					t-if="o.move_type == 'out_invoice' and o.state == 'draft' and not o.pa_doc_name">Draft
					Invoice</span>
				<t t-if="o.move_type == 'out_invoice' and o.state == 'cancel'"> Cancelled <span
						t-field="o.pa_doc_name" />
				</t>
				<t t-if="o.move_type == 'out_invoice' and o.state == 'annul'"> Annulled <span
						t-field="o.pa_doc_name" />
				</t>
				<span
					t-if="o.move_type == 'out_invoice' and o.state == 'cancel' and not o.pa_doc_name">Cancelled
					Invoice</span>
				<t t-if="o.move_type == 'out_refund' and o.pa_doc_name">
					<span t-field="o.pa_doc_name" />
				</t>
				<span t-if="o.move_type == 'out_refund' and not o.pa_doc_name">Refund</span>
				<span t-if="o.move_type == 'in_refund'">Vendor Refund</span>
				<span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
				<span t-esc="(o.name.split('-'))[-1]" />
			</h2>
		</xpath>
	</template>

</odoo> 