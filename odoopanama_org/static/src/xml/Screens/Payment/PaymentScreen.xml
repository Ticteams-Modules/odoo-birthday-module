<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<t t-name="PaymentScreenButtons" t-inherit="point_of_sale.PaymentScreenButtons" t-inherit-mode="extension" owl="1">
    <xpath expr="//div[hasclass('payment-buttons')]" position="inside">
        <!-- Ocultar selector de journals cuando es refund (nota de crédito) -->
        <div class="invoice-journals-container d-flex flex-column gap-2" t-if="!has_payment_refund">
            <t t-foreach="invoice_journals" t-as="journal" t-key="journal.id">
                <button
                    t-on-click="setJournal.bind(this, journal)"
                    class="button btn btn-light btn-lg d-flex justify-content-between align-items-baseline w-100 lh-lg"
                    t-att-class="{ 'highlight active text-action': state.selectedJournalId === journal.id }">
                    <span t-esc="journal.name" />
                    <i class="fa fa-check ms-2" t-if="state.selectedJournalId === journal.id"></i>
                </button>
            </t>
        </div>
    </xpath>
</t>

</templates>
