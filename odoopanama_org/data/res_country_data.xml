<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pa_partner_address_form" model="ir.ui.view">
        <field name="name">pa.partner.form.address</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="900"/>
        <field name="arch" type="xml">
            <form>
                <div class="o_address_format">
                    <field name="parent_id" invisible="1"/>
                    <field name="type" invisible="1"/>
                    <field name="street" placeholder="Street" class="o_address_street" readonly="type == 'contact' and parent_id"/>
                    <field name="street2" invisible="1"/>
                    <field name="l10n_pa_corregimiento" placeholder="Corregimiento..." class="o_address_street"/>
                    <field name="city_id" placeholder="Distrito..."/>
                    <field name="state_id" class="o_address_state" placeholder="State..." options='{"no_open": True}' readonly="type == 'contact' and parent_id"/>
                    <field name="zip" placeholder="ZIP" class="o_address_zip" readonly="type == 'contact' and parent_id"/>
                    <field name="country_id" placeholder="Country" class="o_address_country" options='{"no_open": True, "no_create": True}' readonly="type == 'contact' and parent_id"/>
                </div>                             
            </form>
        </field>
    </record>
    <record id="base.pa" model="res.country">
        <field name="enforce_cities" eval="1" />
        <field name="address_view_id" ref="odoopanama_org.pa_partner_address_form" />
        <field name="address_format" eval="'%(street)s\n%(zip)s%(city)s\n%(state_name)s\n%(country_name)s'"/>
    </record>
</odoo> 
